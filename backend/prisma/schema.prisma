generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}

enum AttendanceMethod {
  QR
  MANUAL
}

enum AttendanceSessionStatus {
  ACTIVE
  CLOSED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum SubjectType {
  THEORY
  PRACTICAL
  LAB
}

model User {
  id       String   @id @default(cuid())
  name     String
  email    String   @unique
  password String
  role     UserRole

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentProfile StudentProfile?
  teacherProfile TeacherProfile?
}

model Department {
  id   String @id @default(cuid())
  name String
  code String @unique

  isActive Boolean @default(true)

  programs Program[]

  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  teachers  TeacherProfile[]
}

model Course {
  id   String @id @default(cuid())
  name String
  code String @unique

  durationYears  Int
  totalSemesters Int

  isActive Boolean @default(true)

  programs Program[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Program {
  id String @id @default(cuid())

  departmentId String
  courseId     String

  name String
  code String @unique

  totalSeats Int

  department Department @relation(fields: [departmentId], references: [id])
  course     Course     @relation(fields: [courseId], references: [id])

  isActive Boolean @default(true)

  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  sections  Section[]
  students  StudentProfile[]
  semesters Semester[]
}

model Section {
  id String @id @default(cuid())

  programId String

  name      String
  batchYear Int

  maxStrength Int

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  program     Program             @relation(fields: [programId], references: [id])
  students    StudentProfile[]
  assignments TeacherAssignment[]

  @@unique([programId, batchYear, name])
}

model StudentProfile {
  userId String @id

  programId String
  sectionId String

  enrollmentNumber String @unique
  rollNumber       Int

  admissionYear Int

  guardianName  String
  guardianPhone String

  address     String
  dateOfBirth DateTime

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  program     Program      @relation(fields: [programId], references: [id])
  section     Section      @relation(fields: [sectionId], references: [id])
  attendances Attendance[]
  photoUrl String?
  @@unique([sectionId, rollNumber])
}

model TeacherProfile {
  userId String @id

  departmentId String

  employeeId String @unique

  designation String

  highestQualification String

  joiningDate DateTime

  primaryPhone String

  alternatePhone String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User                @relation(fields: [userId], references: [id])
  department  Department          @relation(fields: [departmentId], references: [id])
  assignments TeacherAssignment[]
  photoUrl String?
}

model Semester {
  id String @id @default(cuid())

  programId String

  semesterNumber Int

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  program Program @relation(fields: [programId], references: [id])

  subjects Subject[]
  @@unique([programId, semesterNumber])
}

model TeacherAssignment {
  id String @id @default(cuid())

  teacherId String
  subjectId String
  sectionId String

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher TeacherProfile @relation(fields: [teacherId], references: [userId])
  subject Subject @relation(fields: [subjectId], references: [id])
  section Section @relation(fields: [sectionId], references: [id])

  attendanceSessions AttendanceSession[]

  @@unique([teacherId, subjectId, sectionId])
}



model Subject {
  id String @id @default(cuid())

  semesterId String

  name String
  code String @unique

  credits Int

  type SubjectType

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  semester           Semester            @relation(fields: [semesterId], references: [id])
  attendanceSessions AttendanceSession[]
  assignments        TeacherAssignment[]
}

model AttendanceSession {
  id String @id @default(cuid())

  teacherAssignmentId String

  qrToken String @unique

  startTime DateTime
  endTime DateTime?
  attendanceDate DateTime
  room String?
  lectureNumber Int?
  expiresAt DateTime

  status AttendanceSessionStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacherAssignment TeacherAssignment @relation(fields: [teacherAssignmentId], references: [id])

  attendances Attendance[]
  subject     Subject?     @relation(fields: [subjectId], references: [id])
  subjectId   String?
}

model Attendance {
  id String @id @default(cuid())

  attendanceSessionId String
  studentId           String

  scanTime DateTime @default(now())

  status AttendanceStatus @default(PRESENT)
  method AttendanceMethod @default(QR)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attendanceSession AttendanceSession @relation(fields: [attendanceSessionId], references: [id])
  student           StudentProfile    @relation(fields: [studentId], references: [userId])

  @@unique([attendanceSessionId, studentId])
  remarks String?
}
